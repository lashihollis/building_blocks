  create view "quality_measures"."main"."int_vitals__ranked__dbt_tmp" as (
    with unioned as (

select * 
from "quality_measures"."main"."int_vitals__unioned"

),

ranked as (
    select
        *,
        row_number() over (
            partition by patient_id, vital_date, vital_type
            order by
                case source_system
                    when 'payer' then 1
                    when 'ehr' then 2
                    when 'fhir' then 3
                    when 'patient_reported' then 4
                end
        ) as rank
    from unioned
)

select *
from ranked
where rank = 1
  );

